{
  "manifest_version": 3,
  "name": "__MSG_appName__",
  "version": "1.0.0",
  "description": "__MSG_appDescription__",
  "default_locale": "zh_CN",
  "permissions": ["cookies", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/sessionhop-cookie-compass-16.png",
    "32": "icons/sessionhop-cookie-compass-32.png",
    "48": "icons/sessionhop-cookie-compass-48.png",
    "128": "icons/sessionhop-cookie-compass-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "__MSG_appName__",
    "default_icon": {
      "16": "icons/sessionhop-cookie-compass-16.png",
      "32": "icons/sessionhop-cookie-compass-32.png",
      "48": "icons/sessionhop-cookie-compass-48.png",
      "128": "icons/sessionhop-cookie-compass-128.png"
    }
  }
}
