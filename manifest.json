{
  "manifest_version": 3,
  "name": "SessionHop — 一键账号切换",
  "version": "1.0.0",
  "description": "The power to manage multiple accounts across all sites, in one click. 全站点多账号一键切换，基于 Cookie 保存与恢复",
  "permissions": ["cookies", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "options_ui": {
    "page": "src/options/index.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/sessionhop-cookie-compass-16.png",
    "32": "icons/sessionhop-cookie-compass-32.png",
    "48": "icons/sessionhop-cookie-compass-48.png",
    "128": "icons/sessionhop-cookie-compass-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "SessionHop",
    "default_icon": {
      "16": "icons/sessionhop-cookie-compass-16.png",
      "32": "icons/sessionhop-cookie-compass-32.png",
      "48": "icons/sessionhop-cookie-compass-48.png",
      "128": "icons/sessionhop-cookie-compass-128.png"
    }
  }
}
